FROM node:22-alpine AS build
WORKDIR /app
COPY package.json package-lock.json tsconfig.json ./
RUN npm ci
COPY src ./src
RUN npm run build && npm prune --omit=dev

FROM node:22-alpine
RUN addgroup -S agentcert && adduser -S -G agentcert agentcert
WORKDIR /app
COPY --from=build --chown=agentcert:agentcert /app/package.json ./package.json
COPY --from=build --chown=agentcert:agentcert /app/node_modules ./node_modules
COPY --from=build --chown=agentcert:agentcert /app/dist ./dist
RUN mkdir -p /var/lib/agentcert && chown agentcert:agentcert /var/lib/agentcert
USER agentcert
ENV HOST=0.0.0.0 PORT=8787
VOLUME ["/var/lib/agentcert"]
EXPOSE 8787
CMD ["node", "dist/collector-gateway-cli.js"]
