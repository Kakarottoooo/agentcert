{
  "name": "agentcert-sdk",
  "version": "0.4.0",
  "description": "TypeScript SDK for AgentCert hosted evidence, remote collectors, and controlled action runtimes.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kakarottoooo/agentcert.git",
    "directory": "packages/agentcert-sdk"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.js"
    },
    "./remote-collector.schema.json": "./remote-collector.schema.json"
  },
  "bin": {
    "agentcert-collector-gateway": "dist/collector-gateway-cli.js",
    "agentcert-collector-conformance": "dist/gateway-conformance-cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "remote-collector.schema.json",
    "package.json"
  ],
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json && tsc -p tsconfig.runtime-vendor.json",
    "test": "npm run build && vitest run tests",
    "prepack": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.13"
  }
}
