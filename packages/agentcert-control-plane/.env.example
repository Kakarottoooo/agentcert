NODE_ENV=production
HOST=0.0.0.0
PORT=8787
AGENTCERT_PUBLIC_URL=https://app.example.com
DATABASE_URL=postgresql://postgres:password@db.example.supabase.co:5432/postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace-me
SUPABASE_SECRET_KEY=sb_secret_replace-me
AGENTCERT_STORAGE_BUCKET=agentcert-evidence
AGENTCERT_DASHBOARD_DIR=../../public-demo/agentcert-monitor
AGENTCERT_MAX_ARTIFACT_BYTES=20971520

# Local development only. Production refuses to start when this is true.
AGENTCERT_DEV_MODE=false

# Legacy SUPABASE_ANON_KEY and SUPABASE_SERVICE_ROLE_KEY variables remain
# accepted as fallbacks for existing deployments.
