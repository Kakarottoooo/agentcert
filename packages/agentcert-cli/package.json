{
  "name": "agentcert",
  "version": "0.1.0",
  "description": "Unified AgentCert evidence packet and report CLI.",
  "type": "module",
  "bin": {
    "agentcert": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json",
    "prepack": "npm run build",
    "test": "vitest run tests",
    "demo:report": "node dist/cli.js report --mcpbench ../../examples/reports/passing/results.json --out .agentcert/demo --subject demo-agent"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.13"
  },
  "optionalDependencies": {
    "pg": "^8.16.3"
  }
}
