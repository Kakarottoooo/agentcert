{
  "name": "agentcert",
  "version": "0.1.1",
  "description": "Regression CI, evidence reports, and failure corpus tooling for browser agents.",
  "type": "module",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Kakarottoooo/agentcert#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kakarottoooo/agentcert.git",
    "directory": "packages/agentcert-cli"
  },
  "bugs": {
    "url": "https://github.com/Kakarottoooo/agentcert/issues"
  },
  "keywords": [
    "agent",
    "browser-agent",
    "ci",
    "playwright",
    "agent-security",
    "llm",
    "mcp",
    "tripwire",
    "evidence"
  ],
  "bin": {
    "agentcert": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json",
    "prepack": "npm run build",
    "test": "vitest run tests",
    "demo:report": "node dist/cli.js report --mcpbench ../../examples/reports/passing/results.json --out .agentcert/demo --subject demo-agent"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.13"
  },
  "optionalDependencies": {
    "pg": "^8.16.3"
  }
}
