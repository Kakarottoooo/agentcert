{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentcert.dev/schemas/sandbox-vendor-egress.v0.4.json",
  "title": "AgentCert Bounded Vendor Sandbox Egress v0.4",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "kind", "implementation", "vendor", "environment", "generatedAt", "verdict", "summary", "checks", "policy", "audit", "disclaimer"],
  "properties": {
    "schemaVersion": { "const": "agentcert.sandbox_vendor_egress.v0.4" },
    "kind": { "const": "agentcert.sandbox_vendor_egress" },
    "implementation": { "const": "stripe-payment-intent-readonly" },
    "vendor": { "const": "stripe" },
    "environment": { "const": "sandbox" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "verdict": {
      "type": "object",
      "additionalProperties": false,
      "required": ["passed", "score"],
      "properties": {
        "passed": { "type": "boolean" },
        "score": { "type": "integer", "minimum": 0, "maximum": 100 }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["passed", "failed", "total"],
      "properties": {
        "passed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "total": { "type": "integer", "minimum": 1 }
      }
    },
    "checks": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status", "message"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "status": { "enum": ["passed", "failed"] },
          "message": { "type": "string", "minLength": 1 }
        }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowedOrigins", "allowedMethods", "allowedResources", "timeoutMs", "maxRequestsPerMinute"],
      "properties": {
        "allowedOrigins": { "const": ["https://api.stripe.com"] },
        "allowedMethods": { "const": ["GET"] },
        "allowedResources": { "const": ["stripe.payment_intent.retrieve", "stripe.payment_intent.list"] },
        "timeoutMs": { "type": "integer", "minimum": 100, "maximum": 30000 },
        "maxRequestsPerMinute": { "type": "integer", "minimum": 1, "maximum": 60 }
      }
    },
    "audit": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["requestId", "timestamp", "vendor", "resource", "method", "origin", "outcome", "durationMs"],
        "properties": {
          "requestId": { "type": "string", "minLength": 1 },
          "timestamp": { "type": "string", "format": "date-time" },
          "vendor": { "const": "stripe" },
          "resource": { "enum": ["stripe.payment_intent.retrieve", "stripe.payment_intent.list"] },
          "method": { "const": "GET" },
          "origin": { "const": "https://api.stripe.com" },
          "outcome": { "enum": ["allowed", "denied", "rate_limited", "timeout", "http_error", "failed"] },
          "durationMs": { "type": "integer", "minimum": 0 },
          "status": { "type": "integer", "minimum": 100, "maximum": 599 },
          "errorCode": { "enum": ["ORIGIN_DENIED", "METHOD_DENIED", "RESOURCE_DENIED", "RATE_LIMITED", "TIMEOUT", "HTTP_ERROR", "REQUEST_FAILED"] }
        }
      }
    },
    "observation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "object", "livemode"],
      "properties": {
        "id": { "type": "string", "pattern": "^pi_[A-Za-z0-9]{8,128}$" },
        "object": { "const": "payment_intent" },
        "livemode": { "const": false },
        "amount": { "type": "number" },
        "amountCapturable": { "type": "number" },
        "amountReceived": { "type": "number" },
        "currency": { "type": "string" },
        "status": { "type": "string" },
        "created": { "type": "number" }
      }
    },
    "disclaimer": { "type": "string", "minLength": 1 }
  }
}
