{
  "schemaVersion": "1",
  "subject": {
    "name": "demo-agent",
    "type": "agent"
  },
  "artifacts": {
    "mcpbench": "examples/reports/passing/results.json",
    "tripwire": "packages/tripwire-ci/.tripwire/latest/tripwire-result.json",
    "onegent": "packages/onegent-runtime/.onegent/procurement/audit-packet.json"
  },
  "outputDir": ".agentcert/latest",
  "run": {
    "report": {
      "enabled": true,
      "outDir": ".agentcert/latest"
    },
    "corpus": {
      "path": ".agentcert/corpus/corpus.jsonl",
      "reviewsPath": ".agentcert/corpus/failure-reviews.jsonl",
      "replace": true
    },
    "monitor": {
      "outputs": [".agentcert/latest/monitor.json"]
    },
    "dataset": {
      "reviewedOut": ".agentcert/latest/reviewed-failure-dataset.jsonl"
    },
    "gate": {
      "failOnVerdict": true
    }
  }
}
