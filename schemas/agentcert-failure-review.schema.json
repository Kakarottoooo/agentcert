{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentcert.dev/schemas/agentcert-failure-review.schema.json",
  "title": "AgentCertFailureReview",
  "description": "Human taxonomy review record. These records turn automatic failure labels into a reusable correction dataset that can be applied to future corpus ingests.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "kind", "id", "reviewedAt", "reviewer", "status", "target", "type"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1"
    },
    "kind": {
      "type": "string",
      "const": "agentcert.failure_review"
    },
    "id": {
      "type": "string"
    },
    "reviewedAt": {
      "type": "string",
      "format": "date-time"
    },
    "reviewer": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["confirmed", "corrected"]
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["patternKey"],
      "properties": {
        "patternKey": {
          "type": "string"
        },
        "recordId": {
          "type": "string"
        },
        "runId": {
          "type": "string"
        },
        "product": {
          "type": "string"
        },
        "scenarioName": {
          "type": "string"
        },
        "faultName": {
          "type": "string"
        }
      }
    },
    "suggestedType": {
      "$ref": "#/$defs/failureType"
    },
    "type": {
      "$ref": "#/$defs/failureType"
    },
    "note": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Reviewer confidence in the effective taxonomy label, normalized from 0 to 1."
    },
    "evidenceContext": {
      "$ref": "#/$defs/evidenceContext"
    },
    "taxonomyRationale": {
      "$ref": "#/$defs/taxonomyRationale"
    }
  },
  "$defs": {
    "evidenceContext": {
      "type": "object",
      "additionalProperties": false,
      "description": "Pointers and snippets that explain where the reviewer observed the relevant behavior.",
      "properties": {
        "firstDivergenceSnippet": {
          "type": "string"
        },
        "screenshotPath": {
          "type": "string"
        },
        "screenshotUrl": {
          "type": "string"
        },
        "tracePath": {
          "type": "string"
        },
        "stepIndex": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "taxonomyRationale": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primaryReason"],
      "properties": {
        "primaryReason": {
          "type": "string",
          "minLength": 1
        },
        "supportingSignals": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "contradictingSignals": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "classifierLimitation": {
          "type": "string"
        }
      }
    },
    "failureType": {
      "type": "string",
      "enum": [
        "prompt_injection",
        "wrong_click",
        "timeout",
        "verification_gap",
        "silent_partial_success",
        "network_failure",
        "ui_drift",
        "policy_or_approval",
        "agent_connection",
        "console_error",
        "assertion_failure",
        "unknown_failure"
      ]
    }
  }
}
