{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentcert.dev/schemas/agentcert-corpus-record.schema.json",
  "title": "AgentCertCorpusRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "id",
    "ingestedAt",
    "subject",
    "agentName",
    "agentVersion",
    "product",
    "phase",
    "runId",
    "timestamp",
    "score",
    "passed",
    "evidenceCount",
    "highOrCriticalEvidenceCount",
    "failurePatterns",
    "artifacts",
    "sourcePath"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1"
    },
    "kind": {
      "type": "string",
      "enum": ["product_run", "scenario_run"]
    },
    "id": {
      "type": "string"
    },
    "ingestedAt": {
      "type": "string",
      "format": "date-time"
    },
    "subject": {
      "type": "string"
    },
    "agentName": {
      "type": "string",
      "description": "Agent or adapter name derived from the source artifact or subject."
    },
    "agentVersion": {
      "type": "string",
      "description": "Agent version label for trend analysis. Use unversioned when no version is available."
    },
    "product": {
      "type": "string",
      "enum": ["mcpbench", "tripwire-ci", "onegent-runtime", "agentcert-cli"]
    },
    "phase": {
      "type": "string",
      "enum": ["pre-release", "runtime"]
    },
    "runId": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "passed": {
      "type": "boolean"
    },
    "scenarioName": {
      "type": "string"
    },
    "faultName": {
      "type": "string"
    },
    "durationMs": {
      "type": "number",
      "minimum": 0
    },
    "stepCount": {
      "type": "number",
      "minimum": 0
    },
    "evidenceCount": {
      "type": "integer",
      "minimum": 0
    },
    "highOrCriticalEvidenceCount": {
      "type": "integer",
      "minimum": 0
    },
    "failurePatterns": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key", "severity", "message", "type"],
        "properties": {
          "key": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low", "info"]
          },
          "message": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "description": "AgentCert failure taxonomy bucket for filtering and long-term corpus analysis.",
            "enum": [
              "prompt_injection",
              "wrong_click",
              "timeout",
              "verification_gap",
              "silent_partial_success",
              "network_failure",
              "ui_drift",
              "policy_or_approval",
              "agent_connection",
              "console_error",
              "assertion_failure",
              "unknown_failure"
            ]
          },
          "scenarioName": {
            "type": "string"
          },
          "faultName": {
            "type": "string"
          }
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "sourcePath": {
      "type": "string"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
