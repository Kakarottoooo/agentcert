{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentcert.dev/schemas/agentcert-evidence-bundle.schema.json",
  "title": "AgentCertEvidenceBundle",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "kind", "runId", "generatedAt", "subject", "verdict", "summary", "results", "evidence", "artifacts", "standards"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1"
    },
    "kind": {
      "type": "string",
      "const": "agentcert.evidence_bundle"
    },
    "runId": {
      "type": "string"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type"],
      "properties": {
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": ["agent", "mcp-server", "tool", "application", "unknown"]
        }
      }
    },
    "verdict": {
      "type": "object",
      "additionalProperties": false,
      "required": ["passed", "score", "level"],
      "properties": {
        "passed": {
          "type": "boolean"
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "level": {
          "type": "string"
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["products", "criticalEvidence", "highEvidence", "totalEvidence"],
      "properties": {
        "products": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "criticalEvidence": {
          "type": "integer",
          "minimum": 0
        },
        "highEvidence": {
          "type": "integer",
          "minimum": 0
        },
        "totalEvidence": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "results": {
      "type": "array",
      "items": {
        "$ref": "agentcert-result.schema.json"
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "agentcert-evidence.schema.json"
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "standards": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "status", "note"],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["mapped", "planned"]
          },
          "note": {
            "type": "string"
          }
        }
      }
    }
  }
}
