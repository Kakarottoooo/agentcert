{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentcert.dev/schemas/agentcert-evidence-bundle.schema.json",
  "title": "AgentCertEvidenceBundle",
  "description": "Stable AgentCert evidence packet contract. Required fields identify the subject, verdict, source results, evidence items, artifacts, and standards mappings needed for independent review.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaName",
    "schemaVersion",
    "schemaSemver",
    "kind",
    "runId",
    "generatedAt",
    "subject",
    "verdict",
    "summary",
    "results",
    "evidence",
    "artifacts",
    "standards"
  ],
  "properties": {
    "schemaName": {
      "type": "string",
      "const": "agentcert.evidence_bundle",
      "description": "Stable schema identifier for external evidence consumers."
    },
    "schemaVersion": {
      "type": "string",
      "const": "agentcert.evidence.v0.1",
      "description": "Stable AgentCert evidence bundle schema version."
    },
    "schemaSemver": {
      "type": "string",
      "const": "0.1.0",
      "description": "Semver release of the evidence bundle schema."
    },
    "kind": {
      "type": "string",
      "const": "agentcert.evidence_bundle"
    },
    "runId": {
      "type": "string"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type"],
      "properties": {
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": ["agent", "mcp-server", "tool", "application", "unknown"]
        }
      }
    },
    "verdict": {
      "type": "object",
      "additionalProperties": false,
      "required": ["passed", "score", "level"],
      "properties": {
        "passed": {
          "type": "boolean"
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "level": {
          "type": "string"
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["products", "criticalEvidence", "highEvidence", "totalEvidence"],
      "properties": {
        "products": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "criticalEvidence": {
          "type": "integer",
          "minimum": 0
        },
        "highEvidence": {
          "type": "integer",
          "minimum": 0
        },
        "totalEvidence": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "results": {
      "type": "array",
      "items": {
        "$ref": "agentcert-result.schema.json"
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "agentcert-evidence.schema.json"
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "artifactManifest": {
      "description": "Optional v0.1 byte-level declaration used by hosted reconciliation. Older v0.1 bundles remain readable but are not considered fully reconciled.",
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "entries"],
      "properties": {
        "schemaVersion": {
          "type": "string",
          "const": "agentcert.artifact_manifest.v0.1"
        },
        "entries": {
          "type": "array",
          "maxItems": 500,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "sha256", "sizeBytes", "kind"],
            "properties": {
              "path": { "type": "string", "minLength": 1, "maxLength": 1024 },
              "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
              "sizeBytes": { "type": "integer", "minimum": 0 },
              "kind": { "type": "string", "minLength": 1, "maxLength": 64 }
            }
          }
        }
      }
    },
    "standards": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "status", "note"],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["mapped", "planned"]
          },
          "note": {
            "type": "string"
          }
        }
      }
    }
  }
}
