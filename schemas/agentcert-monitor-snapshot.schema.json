{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentcert.dev/schemas/agentcert-monitor-snapshot.schema.json",
  "title": "AgentCertMonitorSnapshot",
  "description": "Static dashboard contract generated from JSONL, SQLite, or Postgres corpus storage. The UI reads this snapshot instead of connecting to storage directly.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "kind", "generatedAt", "subject", "summary", "filters", "lifecycle", "recentRuns", "failurePatterns", "links"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1"
    },
    "kind": {
      "type": "string",
      "const": "agentcert.monitor_snapshot"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "subject": {
      "type": "string"
    },
    "summary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "totalRecords",
        "passedRecords",
        "failedRecords",
        "passRate",
        "byProduct",
        "byFault",
        "byAgent",
        "byVersion",
        "byFailureType",
        "taxonomy",
        "topFailurePatterns"
      ]
    },
    "filters": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agents", "faults", "versions", "failureTypes", "products"],
      "properties": {
        "agents": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "faults": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "versions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "failureTypes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "products": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "lifecycle": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "phase", "description", "recordCount", "passedCount", "failedCount", "passRate", "status"],
        "properties": {
          "id": {
            "type": "string",
            "enum": ["mcpbench", "tripwire-ci", "onegent-runtime"]
          },
          "name": {
            "type": "string"
          },
          "phase": {
            "type": "string",
            "enum": ["Before release", "After release"]
          },
          "description": {
            "type": "string"
          },
          "recordCount": {
            "type": "integer",
            "minimum": 0
          },
          "passedCount": {
            "type": "integer",
            "minimum": 0
          },
          "failedCount": {
            "type": "integer",
            "minimum": 0
          },
          "passRate": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "status": {
            "type": "string",
            "enum": ["passing", "failing", "waiting"]
          }
        }
      }
    },
    "recentRuns": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "id",
          "product",
          "phase",
          "subject",
          "agentName",
          "agentVersion",
          "failureTypes",
          "failurePatterns",
          "taxonomyReviewStatus",
          "reviewedFailureCount",
          "unreviewedFailureCount",
          "passed",
          "score",
          "timestamp",
          "evidenceCount",
          "artifacts"
        ]
      }
    },
    "failurePatterns": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key", "count", "severity", "message", "type"],
        "properties": {
          "key": {
            "type": "string"
          },
          "count": {
            "type": "integer",
            "minimum": 1
          },
          "severity": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "type": {
            "type": "string"
          }
        }
      }
    },
    "links": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "detailUrl": {
          "type": "string"
        }
      }
    }
  }
}
