{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentcert.app/schemas/agentcert-action-mandate.schema.json",
  "title": "AgentCert Action Mandate v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "mandateId", "issuer", "subject", "scope", "policySha256", "validFrom", "expiresAt", "issuedAt", "digestSha256", "sourceSignature"],
  "properties": {
    "schemaVersion": { "const": "agentcert.action_mandate.v0.1" },
    "mandateId": { "type": "string", "minLength": 1, "maxLength": 200 },
    "issuer": {
      "type": "object", "additionalProperties": false, "required": ["id", "type"],
      "properties": { "id": { "type": "string", "minLength": 1 }, "type": { "enum": ["human", "organization", "service"] } }
    },
    "subject": {
      "type": "object", "additionalProperties": false, "required": ["principalId"],
      "properties": { "principalId": { "type": "string", "minLength": 1 }, "agentVersion": { "type": "string" } }
    },
    "scope": {
      "type": "object", "additionalProperties": false, "required": ["actionTypes", "targetSystems", "permissions"],
      "properties": {
        "actionTypes": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "enum": ["SUBMIT", "PAY", "SEND", "UPDATE"] } },
        "targetSystems": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "permissions": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "businessObjectIds": { "type": "array", "uniqueItems": true, "items": { "type": "string" } },
        "recipients": { "type": "array", "uniqueItems": true, "items": { "type": "string" } },
        "currencies": { "type": "array", "uniqueItems": true, "items": { "type": "string", "pattern": "^[A-Z]{3}$" } },
        "maxAmount": { "type": "number", "minimum": 0 }
      }
    },
    "expectedOutcome": { "type": "object" },
    "policySha256": { "$ref": "#/$defs/sha256" },
    "validFrom": { "type": "string", "format": "date-time" },
    "expiresAt": { "type": "string", "format": "date-time" },
    "issuedAt": { "type": "string", "format": "date-time" },
    "digestSha256": { "$ref": "#/$defs/sha256" },
    "sourceSignature": { "$ref": "#/$defs/signature" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "signature": {
      "type": "object", "additionalProperties": false, "required": ["algorithm", "keyId", "signature"],
      "properties": { "algorithm": { "const": "Ed25519" }, "keyId": { "type": "string", "minLength": 1 }, "signature": { "type": "string", "minLength": 1 } }
    }
  }
}
